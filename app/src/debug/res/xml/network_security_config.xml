<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug builds may be inspected with Charles or another local HTTPS proxy. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
